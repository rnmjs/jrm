{
  "name": "jrm",
  "version": "0.4.2",
  "private": true,
  "description": "A fast and simple version manager for JavaScript runtimes and package managers, supporting Node.js, Bun, Deno, npm, Yarn and pnpm.",
  "type": "module",
  "scripts": {
    "build": "./build.sh",
    "prepare": "fenge install",
    "release": "pnpm build",
    "style": "fenge",
    "style:update": "fenge -u",
    "test": "pnpm style && tsc --noEmit && vitest run --coverage --coverage.reporter=json-summary --coverage.reporter=html && make-coverage-badge --output-path badge/coverage.svg"
  },
  "dependencies": {
    "commander": "14.0.3",
    "decompress": "4.2.1",
    "registry-url": "7.2.0",
    "semver": "7.7.4"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@rnm/tscx": "0.3.10",
    "@types/decompress": "4.2.7",
    "@types/node": "22.19.17",
    "@types/semver": "7.7.1",
    "@vitest/coverage-v8": "4.1.5",
    "esbuild": "0.28.0",
    "fenge": "0.13.3",
    "make-coverage-badge": "1.2.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "devEngines": {
    "runtime": [
      {
        "name": "node",
        "version": ">=22.19.0"
      },
      {
        "name": "deno",
        "version": "^2.6.3",
        "onFail": "warn"
      }
    ],
    "packageManager": {
      "name": "pnpm",
      "version": "10.23.0"
    }
  }
}
